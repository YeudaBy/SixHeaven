<!--
    Stylised "6" icon — stroke-based so it renders correctly as a monochrome
    notification small icon and Quick Settings tile icon on all API levels.
    The tail sweeps up like a flame, matching the brand logo vibe.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
        Path breakdown:
          M15,2               – flame tip (top of the "6" tail)
          C18,3.5 20,9 18,13.5 – arm curving down-right into the bowl
          A6.5,6.5,0,0,1,12,23 – short clockwise arc: top-right → bottom of bowl
          A6.5,6.5,0,1,1,18,13.5 – long clockwise arc: bottom → left → top → back
        Together the two arcs draw one complete closed circle (the bowl).
    -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M15,2C18,3.5 20,9 18,13.5A6.5,6.5,0,0,1,12,23A6.5,6.5,0,1,1,18,13.5" />

</vector>
